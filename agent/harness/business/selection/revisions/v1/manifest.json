{
  "schemaVersion": 1,
  "businessId": "selection",
  "version": "v1",
  "writeScope": [
    "selection.members",
    "selection.order"
  ],
  "operations": {
    "inspect": {
      "entryPhase": "read-current",
      "phases": [
        {
          "id": "read-current",
          "kind": "context",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Read the authoritative current checkout and selected roster.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report only the current ordered roster and bound scheme version.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report that the current roster could not be read and give the typed recovery action.",
          "terminalState": "aborted"
        }
      ]
    },
    "search": {
      "entryPhase": "resolve-operator",
      "phases": [
        {
          "id": "resolve-operator",
          "kind": "evidence",
          "tools": ["def.data.resource.operator_catalog"],
          "writes": [],
          "instructions": "Resolve the user's complete operator wording to exact stable catalog identities. For an explicit request to browse the local operator library or replacement candidates, use one empty query and preserve catalogCount, exhaustive and truncated. Never guess an id or call a bounded page the whole catalog.",
          "resultTransitions": [
            {"path": "catalogCount", "equals": 0, "target": "catalog-unavailable"}
          ],
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Return exact matches and any remaining ambiguity. For a browse result, report catalogCount separately from the bounded candidate count and explicitly state when truncated=true.",
          "terminalState": "completed"
        },
        {
          "id": "catalog-unavailable",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "The selection-screen local operator library is currently empty. Report this as a local catalog-source problem, not proof that the operator does not exist in the game or in external knowledge.",
          "terminalState": "aborted"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "State that no exact operator identity was established.",
          "terminalState": "aborted"
        }
      ]
    },
    "add": {
      "entryPhase": "read-current",
      "phases": [
        {
          "id": "read-current",
          "kind": "context",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Read the current ordered roster and checkout before constructing the addition.",
          "transitions": {"onSuccess": "resolve-operator", "onFailure": "failed"}
        },
        {
          "id": "resolve-operator",
          "kind": "evidence",
          "tools": ["def.data.resource.operator_catalog"],
          "writes": [],
          "instructions": "Resolve only the operator being added, construct the complete one-to-four member roster, and preserve every retained operator in order.",
          "transitions": {"onSuccess": "apply-selection", "onFailure": "failed"}
        },
        {
          "id": "apply-selection",
          "kind": "mutation",
          "tools": ["def.team.selection.apply"],
          "writes": ["selection.members", "selection.order"],
          "instructions": "Apply the complete resulting roster once. Native approval must display the candidate and its downstream cleanup before the product mutation runs.",
          "transitions": {"onSuccess": "verify-visible", "onFailure": "failed"},
          "resultTransitions": [{"path": "transition", "equals": "new-temporary-workspace", "target": "detached"}]
        },
        {
          "id": "verify-visible",
          "kind": "verification",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Verify the visible ordered roster and resulting scheme version.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report the applied or no-op roster, visible result, product cleanup and downstream dispositions.",
          "terminalState": "completed"
        },
        {
          "id": "detached",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report that the disjoint four-person roster was verified in a new temporary workspace and this DEF Session was intentionally detached, so any remaining cross-business plan stopped.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Do not create a partial roster; report the unresolved operator or invalid team size.",
          "terminalState": "aborted"
        }
      ]
    },
    "remove": {
      "entryPhase": "read-current",
      "phases": [
        {
          "id": "read-current",
          "kind": "context",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Read the exact current roster, identify one unambiguous removal target, and construct the complete remaining roster.",
          "transitions": {"onSuccess": "apply-selection", "onFailure": "failed"}
        },
        {
          "id": "apply-selection",
          "kind": "mutation",
          "tools": ["def.team.selection.apply"],
          "writes": ["selection.members", "selection.order"],
          "instructions": "Apply the complete remaining roster once. Native approval must show the departing operator and product cleanup.",
          "transitions": {"onSuccess": "verify-visible", "onFailure": "failed"},
          "resultTransitions": [{"path": "transition", "equals": "new-temporary-workspace", "target": "detached"}]
        },
        {
          "id": "verify-visible",
          "kind": "verification",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Verify the visible remaining roster and resulting scheme version.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report the applied roster, product cleanup and downstream dispositions.",
          "terminalState": "completed"
        },
        {
          "id": "detached",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report the verified temporary-workspace transition and intentional DEF Session detachment.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Do not remove an ambiguous or absent operator.",
          "terminalState": "aborted"
        }
      ]
    },
    "replace": {
      "entryPhase": "read-current",
      "phases": [
        {
          "id": "read-current",
          "kind": "context",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Read the current roster and determine which current slot is being replaced.",
          "transitions": {"onSuccess": "resolve-operator", "onFailure": "failed"}
        },
        {
          "id": "resolve-operator",
          "kind": "evidence",
          "tools": ["def.data.resource.operator_catalog"],
          "writes": [],
          "instructions": "Resolve the replacement operator to one exact stable id and construct the complete ordered replacement roster.",
          "transitions": {"onSuccess": "apply-selection", "onFailure": "failed"}
        },
        {
          "id": "apply-selection",
          "kind": "mutation",
          "tools": ["def.team.selection.apply"],
          "writes": ["selection.members", "selection.order"],
          "instructions": "Apply the complete ordered replacement once. Native approval must show the replacement and downstream invalidations.",
          "transitions": {"onSuccess": "verify-visible", "onFailure": "failed"},
          "resultTransitions": [{"path": "transition", "equals": "new-temporary-workspace", "target": "detached"}]
        },
        {
          "id": "verify-visible",
          "kind": "verification",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Verify the visible replacement roster and resulting scheme version.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report the applied replacement, product cleanup and downstream dispositions.",
          "terminalState": "completed"
        },
        {
          "id": "detached",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report that the verified full-team replacement entered a new temporary workspace and intentionally detached this DEF Session.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Ask only for the missing replacement slot or exact operator identity.",
          "terminalState": "aborted"
        }
      ]
    },
    "reorder": {
      "entryPhase": "read-current",
      "phases": [
        {
          "id": "read-current",
          "kind": "context",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Read the ordered roster, preserve the exact member set, and construct the complete requested order.",
          "transitions": {"onSuccess": "apply-selection", "onFailure": "failed"}
        },
        {
          "id": "apply-selection",
          "kind": "mutation",
          "tools": ["def.team.selection.apply"],
          "writes": ["selection.members", "selection.order"],
          "instructions": "Apply one complete order once; do not model reordering as remove plus add. Native approval remains mandatory.",
          "transitions": {"onSuccess": "verify-visible", "onFailure": "failed"},
          "resultTransitions": [{"path": "transition", "equals": "new-temporary-workspace", "target": "detached"}]
        },
        {
          "id": "verify-visible",
          "kind": "verification",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Verify the visible order, unchanged member set and resulting scheme version.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report the applied or no-op order and downstream dispositions.",
          "terminalState": "completed"
        },
        {
          "id": "detached",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report the verified temporary-workspace transition and intentional DEF Session detachment.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report duplicated, missing, or unknown roster members.",
          "terminalState": "aborted"
        }
      ]
    },
    "analyze": {
      "entryPhase": "read-current",
      "phases": [
        {
          "id": "read-current",
          "kind": "context",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Bind the analysis to the current ordered roster and scheme version.",
          "transitions": {"onSuccess": "resolve-candidate", "onFailure": "failed"}
        },
        {
          "id": "resolve-candidate",
          "kind": "evidence",
          "tools": ["def.data.resource.operator_catalog"],
          "writes": [],
          "instructions": "Resolve any proposed new operator exactly. Catalog identity is fact; strategic claims require scoped evidence and may remain unsupported in V1.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Explain direct roster and downstream state impact without applying.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "State which identity or current-state fact is missing.",
          "terminalState": "aborted"
        }
      ]
    },
    "apply": {
      "entryPhase": "read-current",
      "phases": [
        {
          "id": "read-current",
          "kind": "context",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Read the authoritative roster and scheme version immediately before constructing the full apply input.",
          "transitions": {"onSuccess": "resolve-operators", "onFailure": "failed"}
        },
        {
          "id": "resolve-operators",
          "kind": "evidence",
          "tools": ["def.data.resource.operator_catalog"],
          "writes": [],
          "instructions": "Resolve every requested roster member to an exact stable id and preserve the requested order.",
          "transitions": {"onSuccess": "apply-selection", "onFailure": "failed"}
        },
        {
          "id": "apply-selection",
          "kind": "mutation",
          "tools": ["def.team.selection.apply"],
          "writes": ["selection.members", "selection.order"],
          "instructions": "Apply the complete ordered roster once through the formal selection capability. Native approval, CAS and product cleanup remain mandatory.",
          "transitions": {"onSuccess": "verify-visible", "onFailure": "failed"},
          "resultTransitions": [{"path": "transition", "equals": "new-temporary-workspace", "target": "detached"}]
        },
        {
          "id": "verify-visible",
          "kind": "verification",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Read current context again and verify the visible ordered roster and new scheme version.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report applied/no-op outcome, visible roster, product cleanup and downstream dispositions.",
          "terminalState": "completed"
        },
        {
          "id": "detached",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report that the disjoint four-person roster was verified in a new temporary workspace and this DEF Session was intentionally detached, so any remaining cross-business plan stopped.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report 未应用 with the exact failed stage and typed recovery action.",
          "terminalState": "aborted"
        }
      ]
    }
  }
}

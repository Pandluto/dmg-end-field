{
  "schemaVersion": 1,
  "businessId": "buff",
  "version": "v1",
  "writeScope": [
    "buff.bindings",
    "buff.stacks",
    "buff.anomaly",
    "buff.combatState"
  ],
  "operations": {
    "inspect": {
      "entryPhase": "read-context",
      "phases": [
        {
          "id": "read-context",
          "kind": "context",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Bind the authoritative current checkout and scheme version.",
          "transitions": {"onSuccess": "read-buttons", "onFailure": "failed"}
        },
        {
          "id": "read-buttons",
          "kind": "context",
          "tools": ["def.node.crud.buttons"],
          "writes": [],
          "instructions": "Read exact target buttons and their current selected BUFF state.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report current BUFF bindings, layers and relevant state for the exact buttons.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report missing checkout/button facts without guessing.",
          "terminalState": "aborted"
        }
      ]
    },
    "resolve": {
      "entryPhase": "resolve-buff",
      "phases": [
        {
          "id": "resolve-buff",
          "kind": "evidence",
          "tools": ["def.data.resource.buff"],
          "writes": [],
          "instructions": "Resolve the complete BUFF name/id to exact typed candidates, source conditions and stack fields.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Return exact ids, source, applicability, stack/coverage facts and ambiguity.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "State that no exact BUFF identity was established.",
          "terminalState": "aborted"
        }
      ]
    },
    "source": {
      "entryPhase": "resolve-buff",
      "phases": [
        {
          "id": "resolve-buff",
          "kind": "evidence",
          "tools": ["def.data.resource.buff"],
          "writes": [],
          "instructions": "Read the typed BUFF source and activation conditions.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Explain only returned source/condition/coverage facts and their scheme applicability.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report unsupported or missing source facts.",
          "terminalState": "aborted"
        }
      ]
    },
    "add": {
      "entryPhase": "read-context",
      "phases": [
        {
          "id": "read-context",
          "kind": "context",
          "tools": ["def.node.crud.context"],
          "writes": [],
          "instructions": "Bind current checkout.",
          "transitions": {"onSuccess": "read-buttons", "onFailure": "failed"}
        },
        {
          "id": "read-buttons",
          "kind": "context",
          "tools": ["def.node.crud.buttons"],
          "writes": [],
          "instructions": "Resolve exact target buttons and current BUFF bindings.",
          "transitions": {"onSuccess": "resolve-buff", "onFailure": "failed"}
        },
        {
          "id": "resolve-buff",
          "kind": "evidence",
          "tools": ["def.data.resource.buff"],
          "writes": [],
          "instructions": "Resolve one exact BUFF and its legal layer/coverage conditions.",
          "transitions": {"onSuccess": "fork-draft", "onFailure": "failed"}
        },
        {
          "id": "fork-draft",
          "kind": "proposal",
          "tools": ["def.node.crud.fork"],
          "writes": [],
          "instructions": "Create one Agent-named child Work Node for the BUFF change.",
          "transitions": {"onSuccess": "edit-buff", "onFailure": "failed"}
        },
        {
          "id": "edit-buff",
          "kind": "mutation",
          "tools": ["def.node.code.apply_patch"],
          "writes": ["buff.bindings", "buff.stacks", "buff.anomaly", "buff.combatState"],
          "instructions": "Add the exact BUFF to the exact button(s). Do not move, replace, copy or delete any skill button.",
          "transitions": {"onSuccess": "validate-draft", "onFailure": "failed"}
        },
        {
          "id": "validate-draft",
          "kind": "verification",
          "tools": ["def.node.crud.validate"],
          "writes": [],
          "instructions": "Validate BUFF references, layers, conflicts, mirrors and button identity preservation.",
          "transitions": {"onSuccess": "diff-draft", "onFailure": "failed"}
        },
        {
          "id": "diff-draft",
          "kind": "verification",
          "tools": ["def.node.crud.diff"],
          "writes": [],
          "instructions": "Verify the semantic diff is BUFF-only.",
          "transitions": {"onSuccess": "use-draft", "onFailure": "failed"}
        },
        {
          "id": "use-draft",
          "kind": "mutation",
          "tools": ["def.node.crud.use"],
          "writes": ["buff.bindings", "buff.stacks", "buff.anomaly", "buff.combatState"],
          "instructions": "Request native approval and use the same validated Work Node revision.",
          "transitions": {"onSuccess": "verify-visible", "onFailure": "failed"}
        },
        {
          "id": "verify-visible",
          "kind": "verification",
          "tools": ["def.node.crud.buttons"],
          "writes": [],
          "instructions": "Read the live target buttons and verify the BUFF binding and layers.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report the visible applied BUFF change and calculation recompute.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report 未应用 with the failed phase; preserve the draft and never mutate button structure.",
          "terminalState": "aborted"
        }
      ]
    },

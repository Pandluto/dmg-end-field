        },
        {
          "id": "verify-visible",
          "kind": "verification",
          "tools": ["def.node.crud.buttons"],
          "writes": [],
          "instructions": "Verify the live buttons no longer carry the binding.",
          "transitions": {"onSuccess": "done", "onFailure": "failed"}
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report the visible removal and calculation recompute.",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report 未应用 without deleting or moving the button.",
          "terminalState": "aborted"
        }
      ]
    },
    "replace": {
      "entryPhase": "read-context",
      "phases": [
        {
          "id": "read-context",
          "kind": "context",
          "tools": ["def.node.crud.context"],

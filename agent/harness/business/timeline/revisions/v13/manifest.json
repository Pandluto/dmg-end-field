    "copy": {
      "entryPhase": "read-context",
      "phases": [
        {
          "id": "read-context",
          "kind": "context",
          "tools": [
            "def.node.crud.context"
          ],
          "writes": [],
          "instructions": "Bind current checkout.",
          "transitions": {
            "onSuccess": "fork-draft",
            "onFailure": "failed"
          }
        },
        {
          "id": "fork-draft",
          "kind": "proposal",
          "tools": [
            "def.node.crud.fork"
          ],
          "writes": [],
          "instructions": "The user supplied the source character and literal grid coordinate. Do not query identity, skill, BUFF, entity or buttons, and do not ask a clarification. Call only native def_node_fork exactly once. Use a natural Chinese name no longer than 20 characters; do not put ids or timestamps in it. The description must be one Chinese sentence of 20-100 characters stating only the source coordinate, target coordinate and that BUFF is not copied; do not enumerate ids, fields or implementation details. Use placement=child and approvalPolicy=ask-on-risk. Do not read or edit until the fork succeeds.",
          "transitions": {
            "onSuccess": "copy-button",
            "onFailure": "failed"
          }
        },
        {
          "id": "copy-button",
          "kind": "mutation",
          "tools": [
            "def.node.code.edit"
          ],
          "writes": [
            "timeline.buttonIdentity",
            "timeline.buttonPosition",
            "timeline.buttonOrder",
            "timeline.structure"
          ],
          "contextSources": [
            {
              "path": "node/working/timeline.json",
              "format": "json-verbatim",
              "maxBytes": 131072
            }
          ],
          "instructions": "The complete authoritative working timeline is bound below as exact verbatim JSON. It is the only source needed for this phase: do not read, query, or inspect another capability. The fork result already supplied the absolute session directory; append node/working/timeline.json to that directory for filePath. Resolve the source object directly from the user's named character and literal grid coordinate: “第N格” means nodeIndex=N-1 on that character's selected row, and @N-L means nodeIndex=N-1 plus lineIndex=L-1. Same-name buttons at any other coordinate are irrelevant. Call native edit exactly once. The edit anchor MUST be the object boundary after the complete source button: oldString starts with the source object's final indented closing brace and comma, then the next existing button's opening brace and unique id line. Never anchor inside the source object, never close it early, and never replace a prefix of it. newString must preserve that boundary while inserting one complete button object before the next existing button. Copy every renderable field from the full source object, changing only the new non-colliding id, literal target nodeIndex/nodeNumber/position, timestamps if needed, and Buff-only state. selectedBuff, panelConfig.selectedBuff, all panelConfig disabled/stack maps, buffStackCounts and anomaly selections on the copy must be empty; preserve the source unchanged. Do not omit customHits, icon, runtime snapshot, anomaly/resistance containers, or line identity. Do not call apply_patch, read, shell, or emit tool-call markup as text.",
          "transitions": {
            "onSuccess": "validate-draft",
            "onFailure": "failed"
          }
        },
        {
          "id": "validate-draft",
          "kind": "verification",
          "tools": [
            "def.node.crud.validate"
          ],
          "writes": [],
          "instructions": "Validate new id, slot, selected operator and mirrors.",
          "transitions": {
            "onSuccess": "diff-draft",
            "onFailure": "failed"
          }
        },
        {
          "id": "diff-draft",
          "kind": "verification",
          "tools": [
            "def.node.crud.diff"
          ],
          "writes": [],
          "instructions": "Verify the new button and no BUFF copy.",
          "transitions": {
            "onSuccess": "use-draft",
            "onFailure": "failed"
          }
        },
        {
          "id": "use-draft",
          "kind": "mutation",
          "tools": [
            "def.node.crud.use"
          ],
          "writes": [
            "timeline.buttonIdentity",
            "timeline.buttonPosition",
            "timeline.buttonOrder",
            "timeline.structure"
          ],
          "instructions": "Use the validated copy Work Node under native approval and the current scheme CAS.",
          "transitions": {
            "onSuccess": "verify-visible",
            "onFailure": "failed"
          }
        },
        {
          "id": "verify-visible",
          "kind": "verification",
          "tools": [
            "def.node.crud.context"
          ],
          "writes": [],
          "instructions": "Verify the current checkout and visible timeline contain the new stable button without copied BUFF state.",
          "transitions": {
            "onSuccess": "done",
            "onFailure": "failed"
          }
        },
        {
          "id": "done",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report the applied copy and visible result in one natural Chinese sentence. Do not expose ids, field names, indexes, percentages, internal phases or implementation details.",
          "exactReply": "复制已完成，目标位置已经更新，没有复制任何 BUFF。",
          "terminalState": "completed"
        },
        {
          "id": "failed",
          "kind": "response",
          "tools": [],
          "writes": [],
          "instructions": "Report only that the copy did not reach verified completion. Do not claim that the checkout is unchanged because application may have succeeded before visible verification failed. Never invent target occupancy, validation failure or another cause that no Tool result established.",
          "exactReply": "复制流程未能完成，最终排轴状态需要重新确认。",
          "terminalState": "aborted"
        }
      ]
    },

{
  "name": "dmg-end-field",
  "private": true,
  "version": "1.7.1",
  "author": "SailStellar <190052366@qq.com>",
  "description": "Desktop shell for dmg-end-field",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "agent:dev": "node agent/dev-agent.cjs",
    "agent:dev:web": "node agent/dev-agent.cjs --open-web",
    "ai-cli:rest": "node scripts/ai-cli-rest-server.mjs",
    "smoke:ai-cli-rest": "node scripts/ai-cli-rest-smoke.mjs",
    "smoke:work-node-sqlite": "node scripts/ai-timeline-work-node-sqlite-smoke.mjs && node scripts/ai-timeline-work-node-rest-smoke.mjs && node scripts/ai-timeline-work-node-backup-restore-smoke.mjs && node scripts/timeline-migration-smoke.mjs",
    "smoke:timeline-bundle": "node scripts/timeline-bundle-v2-smoke.mjs",
    "smoke:timeline-client": "node scripts/run-ts-test.mjs /src/agentKernel/timelineRepository/localTimelineClient.test.ts",
    "smoke:work-node-tree-ui": "node scripts/run-ts-test.mjs /src/agentKernel/timelineWorktree/checkoutLifecycle.test.ts",
    "smoke:workbench-history": "node scripts/run-ts-test.mjs /src/components/CanvasBoard/workbenchAiHistory.test.ts",
    "smoke:workbench-command": "node scripts/run-ts-test.mjs /src/agentKernel/mainWorkbench/commandSchemaRuntime.test.ts",
    "dev": "vite --host 127.0.0.1 --port 3030",
    "assets:release": "node scripts/build-image-release-manifest.mjs",
    "akedb:extract": "node scripts/extract-akedb-raw-index.mjs",
    "operator:imports": "node scripts/build-operator-imports.mjs",
    "operator:validate": "node scripts/validate-operator-outputs.mjs",
    "weapon:build": "node scripts/build-weapon-library.mjs",
    "test": "node scripts/run-ts-test.mjs /src/core/calculators/operatorPanelCalculator.test.ts /src/core/calculators/buffPanelCalculator.test.ts /src/core/calculators/buffZoneCalculator.test.ts /src/core/calculators/resistanceZone.test.ts /src/core/services/extraHitIntegration.test.ts /src/aiCli/aiCliCommandService.test.ts",
    "test:numeric": "node scripts/run-ts-test.mjs /src/core/calculators/operatorPanelCalculator.test.ts /src/core/calculators/buffPanelCalculator.test.ts /src/core/calculators/buffZoneCalculator.test.ts /src/core/calculators/resistanceZone.test.ts /src/core/services/extraHitIntegration.test.ts",
    "test:ai-cli": "node scripts/run-ts-test.mjs /src/aiCli/aiCliCommandService.test.ts",
    "test:operator-panel": "node scripts/run-ts-test.mjs /src/core/calculators/operatorPanelCalculator.test.ts",
    "smoke:operator-config": "node scripts/run-electron-smoke.mjs",
    "build": "tsc && vite build",
    "build:opencode-runtime": "node scripts/build-opencode-runtime.mjs",
    "preview": "vite preview",
    "app:dev": "npm run electron:shell",
    "electron:shell": "concurrently -k \"npm:dev\" \"wait-on tcp:127.0.0.1:3030 && electron . --dev --shell-only\"",
    "electron:dev": "npm run electron:shell",
    "electron:build": "npm run build && npm run build:opencode-runtime && electron-builder --win portable",
    "electron:build:mac": "npm run build && npm run build:opencode-runtime && electron-builder --mac dmg --publish never",
    "electron:build:mac:dir": "npm run build && npm run build:opencode-runtime && electron-builder --mac dir --publish never"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "fuse.js": "^7.3.0",
    "pinyin-pro": "^3.28.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.1.2",
    "electron": "^35.5.1",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.dmg.def",
    "productName": "dmg-end-field",
    "compression": "store",
    "afterSign": "scripts/notarize.cjs",
    "directories": {
      "output": "release"
    },
    "icon": "electron/assets/icon.png",
    "files": [
      "dist/**",
      "electron/**",
      "scripts/ai-cli-rest-server.mjs",
      "scripts/build-image-release-manifest.mjs",
      "agent/server/**",
      "agent/runtime/**",
      "!agent/vendor/**",
      "!agent/dev-agent.cjs",
      "package.json"
    ],
    "asarUnpack": [
      "agent/runtime/opencode-core/bin/**"
    ],
    "win": {
      "icon": "electron/assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}

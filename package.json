  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "exceljs": "^4.4.0",
    "fuse.js": "^7.3.0",
    "pinyin-pro": "^3.28.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "vite": "^7.3.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.1.2",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.dmg.def",
    "productName": "终末地伤害工作台",
    "compression": "normal",
    "afterSign": "scripts/notarize.cjs",
    "directories": {
      "output": "release"
    },
    "icon": "electron/assets/icon.png",
    "files": [
      "dist/**",
      "src/**",
      "electron/**",
      "scripts/ai-cli-rest-server.mjs",
      "scripts/def-core/**",
      "scripts/legacy-fill-service.mjs",
      "scripts/legacy-fill-mcp-stdio.mjs",
      "scripts/build-legacy-fill-runtime.mjs",
      "scripts/build-data-catalog.mjs",
      "scripts/build-data-release-package.mjs",
      "scripts/build-image-release-manifest.mjs",
      "docs/specs/legacy-ai-cli-mcp-extraction/fixtures/legacy-fill-wire-v1.json",
      "agent/server/**",
      "agent/runtime/**",
      "!agent/runtime/def-node-workspace/codec.test.mjs",
      "!agent/runtime/def-opencode-adapter/README.md",
      "!agent/vendor/**",
      "!agent/dev-agent.cjs",
      "package.json"
    ],
    "asarUnpack": [
      "agent/runtime/opencode-core/bin/**",
      "node_modules/@esbuild/**",
      "dist/data/catalog.sqlite"
    ],
    "electronLanguages": [
      "zh-CN"
    ],
    "win": {
      "icon": "electron/assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}

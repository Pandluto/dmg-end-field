{
  "name": "dmg-end-field",
  "private": true,
  "version": "1.8.2",
  "author": "SailStellar <190052366@qq.com>",
  "description": "终末地伤害工作台的桌面壳",
  "type": "module",
  "main": "electron/main.cjs",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "agent:dev": "node agent/dev-agent.cjs",
    "agent:dev:web": "node agent/dev-agent.cjs --open-web",
    "interop": "node scripts/def-codex-interop-client.mjs",
    "interop:hello": "node scripts/def-codex-interop-client.mjs hello",
    "interop:check": "node scripts/def-codex-interop-check.mjs",
    "harness": "node scripts/def-harness-cli.mjs",
    "harness:check": "node scripts/def-harness-check.mjs",
    "ai-cli:rest": "node scripts/ai-cli-rest-server.mjs",
    "smoke:ai-cli-rest": "node scripts/ai-cli-rest-smoke.mjs",
    "smoke:packaged-sidecar": "node scripts/packaged-sidecar-smoke.mjs",
    "smoke:work-node-sqlite": "node scripts/ai-timeline-work-node-sqlite-smoke.mjs && node scripts/ai-timeline-work-node-rest-smoke.mjs && node scripts/ai-timeline-work-node-backup-restore-smoke.mjs && node scripts/timeline-migration-smoke.mjs",
    "smoke:timeline-bundle": "node scripts/timeline-bundle-v2-smoke.mjs",
    "smoke:data-management": "node scripts/data-management-service-smoke.mjs",
    "smoke:data-catalog": "node scripts/data-catalog-build-smoke.mjs",
    "smoke:data-release-builder": "node scripts/data-release-builder-smoke.mjs",
    "dev": "npm run data:catalog && vite --host 127.0.0.1 --port 3030",
    "assets:release": "node scripts/build-image-release-manifest.mjs",
    "akedb:extract": "node scripts/extract-akedb-raw-index.mjs",
    "operator:imports": "node scripts/build-operator-imports.mjs",
    "operator:validate": "node scripts/validate-operator-outputs.mjs",
    "weapon:build": "node scripts/build-weapon-library.mjs",
    "test": "node scripts/run-ts-test.mjs && node agent/runtime/def-node-workspace/codec.test.mjs",
    "test:numeric": "node scripts/run-ts-test.mjs /src/core/calculators/buffPanelCalculator.test.ts /src/core/calculators/buffZoneCalculator.test.ts /src/core/calculators/resistanceZone.test.ts",
    "typecheck": "tsc --noEmit",
    "data:catalog": "node scripts/build-data-catalog.mjs",
    "data:release": "node scripts/build-data-release-package.mjs",
    "build:web": "npm run data:catalog && vite build",
    "check:repo": "node scripts/repository-check.mjs",
    "check:knowledge": "node scripts/def-game-knowledge-contract-check.mjs",
    "audit:dependencies": "npm audit --audit-level=high",
    "check": "npm run check:repo && npm run audit:dependencies && npm run typecheck && npm test && npm run harness:check && npm run check:knowledge && npm run build:web",
    "release:verify": "node scripts/check-release-version.mjs",
    "smoke:operator-config": "node scripts/run-electron-smoke.mjs",
    "build": "npm run opencode-ui:build && npm run typecheck && npm run build:web",
    "opencode-ui:build": "node scripts/build-opencode-ui.mjs",
    "build:opencode-runtime": "node scripts/build-opencode-runtime.mjs",
    "preview": "vite preview",
    "app:dev": "npm run electron:shell",
    "electron:shell": "npm run opencode-ui:build && concurrently -k \"npm:dev\" \"wait-on tcp:127.0.0.1:3030 && electron . --dev --shell-only\"",
    "electron:dev": "npm run electron:shell",
    "electron:build": "npm run build && npm run build:opencode-runtime && electron-builder --win portable",
    "electron:build:mac": "npm run build && npm run build:opencode-runtime && electron-builder --mac dmg --publish never",
    "electron:build:mac:dir": "npm run build && npm run build:opencode-runtime && electron-builder --mac dir --publish never"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "fuse.js": "^7.3.0",
    "pinyin-pro": "^3.28.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "vite": "^7.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.1.2",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.dmg.def",
    "productName": "终末地伤害工作台",
    "compression": "normal",
    "afterSign": "scripts/notarize.cjs",
    "directories": {
      "output": "release"
    },
    "icon": "electron/assets/icon.png",
    "files": [
      "dist/**",
      "src/**",
      "electron/**",
    "scripts/ai-cli-rest-server.mjs",
    "scripts/build-data-catalog.mjs",
    "scripts/build-data-release-package.mjs",
      "scripts/build-image-release-manifest.mjs",
      "agent/server/**",
      "agent/runtime/**",
      "!agent/runtime/def-node-workspace/codec.test.mjs",
      "!agent/runtime/def-opencode-adapter/README.md",
      "!agent/vendor/**",
      "!agent/dev-agent.cjs",
      "package.json"
    ],
  "asarUnpack": [
    "agent/runtime/opencode-core/bin/**",
    "node_modules/@esbuild/**",
    "dist/data/catalog.sqlite"
  ],
    "electronLanguages": [
      "zh-CN"
    ],
    "win": {
      "icon": "electron/assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}

{
  "name": "dmg-end-field",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "agent:dev": "node agent/dev-agent.cjs",
    "agent:dev:web": "node agent/dev-agent.cjs --open-web",
    "dev": "vite --host 127.0.0.1 --port 3030",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "app:dev": "npm run electron:dev",
    "electron:shell": "concurrently -k \"npm:dev\" \"wait-on tcp:127.0.0.1:3030 && electron . --dev --shell-only\"",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on tcp:127.0.0.1:3030 && electron . --dev\"",
    "electron:build": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@maaxyz/maa-node": "^5.10.4",
    "exceljs": "^4.4.0",
    "fuse.js": "^7.3.0",
    "pinyin-pro": "^3.28.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.1.2",
    "electron": "^35.5.1",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.dmg.def",
    "productName": "dmg-end-field",
    "directories": {
      "output": "release"
    },
    "icon": "electron/assets/icon.png",
    "files": [
      "dist/**",
      "electron/**",
      "native/**",
      "agent/**",
      "package.json"
    ],
    "win": {
      "icon": "electron/assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  }
}
